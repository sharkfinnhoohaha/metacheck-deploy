# ─── Clerk (Auth) ────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Point Clerk at the in-app /sign-in and /sign-up routes (app/sign-in, app/sign-up)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Clerk Webhook ────────────────────────────────────────────────────────────
# Create a webhook in Clerk dashboard pointing to: {APP_URL}/api/webhooks/clerk
# Subscribe to: user.created, user.updated, user.deleted
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Supabase (Database) ──────────────────────────────────────────────────────
# Get from https://supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# ─── Stripe (Billing) ─────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Create a webhook pointing to: {APP_URL}/api/webhooks/stripe
# Subscribe to: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products in Stripe, get the recurring price IDs (price_...)
# Monthly:
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
# Annual (add a yearly recurring price to the same products):
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_TEAM_ANNUAL_PRICE_ID=price_...
# One-time "Per Release" credit — create a one-time (non-recurring) price:
STRIPE_PER_RELEASE_PRICE_ID=price_...

# ─── PayPal (alternative billing, optional) ───────────────────────────────────
# Get Client ID/Secret from https://developer.paypal.com → Apps & Credentials
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
# "sandbox" for testing, "live" for production
PAYPAL_ENV=sandbox
# Create subscription Plans → copy the plan IDs (P-...). Monthly (Pro $9, Label $29):
PAYPAL_PRO_PLAN_ID=P-...
PAYPAL_TEAM_PLAN_ID=P-...
# Annual plans (Pro ~$49/yr, Label ~$290/yr):
PAYPAL_PRO_ANNUAL_PLAN_ID=P-...
PAYPAL_TEAM_ANNUAL_PLAN_ID=P-...
# Create a webhook → {APP_URL}/api/webhooks/paypal (all BILLING.SUBSCRIPTION.* events) → copy its Webhook ID
PAYPAL_WEBHOOK_ID=...
# NOTE: per-release one-time credits are handled via Stripe only for now.

# ─── Google Gemini / Vertex AI (AI fixes + artwork QC) ────────────────────────
# Option A — Gemini Developer API key (simplest). Get from https://aistudio.google.com/
# IMPORTANT: enable BILLING / the paid tier before sending real artist data — the
# free tier trains on your content.
GEMINI_API_KEY=AIzaSy...
# Option B — Vertex AI (routes spend through your GCP project so it draws on the
# $300 credit; paid no-training guarantee). Takes precedence over GEMINI_API_KEY.
# Create a GCP project, enable the Vertex AI API, create a service account with
# the "Vertex AI User" role, and download a JSON key. Paste the WHOLE json on one line.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_SERVICE_ACCOUNT_JSON=
# Option C — Vertex AI via Workload Identity Federation (KEYLESS; highest precedence).
# Used in production on Vercel: the per-request VERCEL_OIDC_TOKEN is exchanged via STS
# to impersonate the service account — no long-lived key (works where SA keys are
# blocked by org policy) and draws on the GCP credit. Set GOOGLE_VERTEX_PROJECT +
# GOOGLE_VERTEX_LOCATION above, enable OIDC on the Vercel project, and set:
GCP_WORKLOAD_IDENTITY_AUDIENCE=
GCP_SERVICE_ACCOUNT_EMAIL=
# NOTE: only set the WIF vars in Vercel (not locally) — VERCEL_OIDC_TOKEN only exists
# in Vercel deployments; locally, leave them unset and use GEMINI_API_KEY for dev.
# Optional: override the model preference list (comma-separated, no spaces).
# GEMINI_MODELS=gemini-3.1-flash-lite,gemini-3.5-flash

# ─── Upstash Redis (rate limiting for public AI / search routes) ──────────────
# Create a free Redis DB at https://upstash.com → REST API → copy URL + token.
# If unset, rate limiting no-ops (fine for local dev; configure it in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── App ──────────────────────────────────────────────────────────────────────
# Your deployed URL (no trailing slash). Used for Stripe redirect URLs AND for
# canonical / Open Graph / JSON-LD metadata (see lib/site.ts). In PRODUCTION this
# MUST be the real origin (e.g. https://metacheck-ten.vercel.app or your custom
# domain) — if it's left as a placeholder, OG/canonical tags render broken.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Admin dashboard (/admin) ─────────────────────────────────────────────────
# Deny-by-default. Grant /admin access by Clerk user ID and/or email
# (comma-separated). Leave both unset to keep /admin locked for everyone.
ADMIN_USER_IDS=user_xxx,user_yyy
ADMIN_EMAILS=you@example.com
